#!/bin/sh

set -eu

usage() {
  cat <<'EOF'
Usage: git-publish [remote] [branch]

Push a local branch and set upstream.

Argument handling:
  no args   use remote "origin" and current branch
  1 arg     use remote "origin" and the given branch
  2 args    use <remote> and <branch>
EOF
}

die() {
  printf '%s\n' "$*" >&2
  exit 1
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    -*)
      die "Unknown option: $1"
      ;;
    *)
      break
      ;;
  esac
done

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die 'Not inside a Git repository'

remote=origin
branch=''

case "$#" in
  0)
    branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null || true)
    [ -n "$branch" ] || die 'Could not determine current branch (detached HEAD?)'
    ;;
  1)
    branch=$1
    ;;
  2)
    remote=$1
    branch=$2
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac

if [ "$#" -gt 0 ]; then
  git checkout "$branch" >/dev/null 2>&1 || git checkout -b "$branch"
fi

git push -u "$remote" "$branch"
